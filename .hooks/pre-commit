#!/bin/sh
# Runs before each commit. Install: npm run hooks:install (sets core.hooksPath to .hooks)
# Bypass: SKIP_HOOKS=1 git commit ...
#
# Runs build then unit tests (same as CI-style gate). MCP smoke / examples:smoke are not
# run here—too slow for every commit; use npm run mcp:smoke / examples:smoke before push.

set -e

if [ "$SKIP_HOOKS" = "1" ]; then
  exit 0
fi

ROOT=$(cd "$(dirname "$0")/.." && pwd)
cd "$ROOT"

if [ ! -f package.json ]; then
  exit 0
fi

echo "pre-commit: npm run build"
npm run build

echo "pre-commit: npm test"
npm test
